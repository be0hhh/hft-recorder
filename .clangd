# hft-recorder clangd profile.
# Mirrors the parent repo style, but points at the app-local build tree.
# Reference environment: WSL/Linux build from apps/hft-recorder -> build/compile_commands.json.

CompileFlags:
  CompilationDatabase: build
  Add:
    - -std=c++23
    - -Wall
    - -Wextra
  Remove:
    - -march=native
    - -flto

Diagnostics:
  UnusedIncludes: Strict
  IncludeCleaner: true

ClangTidy:
  Add:
    - performance-*
    - bugprone-*
    - readability-*
    - modernize-use-nullptr
    - modernize-use-equals-default
    - misc-move-const-arg
    - misc-unused-using-decls
    - cppcoreguidelines-pro-type-member-init
    - cppcoreguidelines-pro-bounds-pointer-arithmetic
    - cppcoreguidelines-pro-type-reinterpret-cast
    - cppcoreguidelines-avoid-c-arrays
  FastCheckFilter: Loose

Index:
  Background: Build

Completion:
  AllScopes: Yes

InlayHints:
  ParameterNames: true
  DeducedTypes: true
  BlockEnd: true
